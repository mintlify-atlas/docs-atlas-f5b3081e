  "keyFeatures": [
    "Microservices architecture with Spring Boot",
    "Real-time order management with WebSockets",
    "QR code-based reservation validation",
    "AI-powered chatbot for customer support",
    "OAuth 2.0 and JWT authentication",
    "Multi-database support (PostgreSQL, MongoDB, Redis)",
    "Asynchronous messaging with RabbitMQ",
    "Payment processing with receipt validation",
    "Event and table reservation system",
    "Administrative dashboard with reporting"
  ],
  "publicApiSurface": [
    "POST /auth/login - User authentication",
    "POST /auth/register - User registration",
    "POST /auth/github - GitHub OAuth login",
    "POST /auth/google - Google OAuth login",
    "GET /eventos - List all events",
    "POST /eventos - Create event",
    "GET /pedido - List orders",
    "POST /pedido - Create order",
    "POST /pedido/newPlato - Add dish to order",
    "GET /pedido/reporte/ventas-por-mesa - Sales report by table",
    "GET /pedido/reporte/platos-mas-vendidos - Most sold dishes report"
  ]
